# ============================================
# 健康信息系统 .gitignore
# 更新日期: 2026-04-14
# ============================================

# ==================== 环境配置与敏感信息 ====================
# 环境变量文件（包含API密钥、数据库密码等敏感信息）
.env
.env.local
.env.*.local
!.env.example          # 保留示例文件供参考

# ==================== Python 缓存与编译文件 ====================
# Python 字节码缓存
__pycache__/
**/__pycache__/
*.py[cod]
**/*.py[cod]
*$py.class
*.so
.Python

# Python 分发/打包
build/
dist/
*.egg-info/
*.egg

# ==================== 虚拟环境 ====================
# 虚拟环境目录（不同命名习惯）
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/

# ==================== 数据文件（隐私与体积考虑） ====================
# 原始数据目录（包含敏感或大型数据文件）
data/raw/*
!data/raw/.gitkeep     # 保留目录结构

# 处理后数据目录（可重新生成的中间文件）
data/processed/*
!data/processed/.gitkeep

# 临时数据文件
data/temp/
data/cache/

# 保留地理数据（通常较小且必要）
!data/geojson/         # 保留地理数据目录
!data/geojson/**/*     # 保留所有geojson文件

# ==================== 数据库文件 ====================
# SQLite 数据库文件
*.db
*.db-journal
*.sqlite
*.sqlite3

# 数据库迁移备份
*.db.bak

# ==================== 日志文件 ====================
# 应用日志
logs/
*.log
log/

# 调试日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==================== 第三方服务与工具 ====================
# Redis 服务（可独立安装）
Redis-x64-*/
redis-*/

# Node.js 依赖（如有前端构建）
node_modules/
package-lock.json
yarn.lock

# ==================== 测试与报告 ====================
# 测试覆盖率报告
htmlcov/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# 性能测试与审计报告（可重新生成）
reports/
!reports/.gitkeep

# ==================== IDE 与编辑器 ====================
# VS Code
.vscode/
!.vscode/settings.json.example
!.vscode/extensions.json.example

# PyCharm / IntelliJ
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
#*#
.#*

# ==================== 操作系统文件 ====================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Linux
*~
.nfs*

# ==================== 压缩与归档文件 ====================
# 大型压缩文件（源代码应直接管理）
*.zip
*.tar.gz
*.tar.bz2
*.rar
*.7z

# 例外：保留文档中引用的示例压缩文件
!docs/**/*.zip

# ==================== 文档生成文件 ====================
# 生成的PDF报告（可由Markdown重新生成）
*.pdf

# 生成的Excel文件（可由数据重新生成）
*.xlsx
*.xls

# 生成的音频/视频文件
*.mp3
*.mp4
*.avi
*.mov

# ==================== Streamlit 配置 ====================
.streamlit/secrets.toml

# ==================== 临时文件 ====================
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup

# ==================== 本地开发配置 ====================
# 本地开发覆盖配置
local_settings.py
settings_local.py

# 调试配置
.debug/

# ==================== 外部仓库 ====================
# 外部研究仓库（包含嵌套的Git仓库，避免提交问题）
external_repos/

# ==================== 其他 ====================
# 个人笔记
notes/
TODO.md
NOTES.md

# 归档文件
archive/
archived/
deprecated/
